; Helper functions
(defun nlcs-get-discipline-name (code)
  (cdr (assoc code *nlcs-disciplines*)))

(defun nlcs-get-layers-for-discipline (code)
  (cdr (assoc code *nlcs-layers*)))

(defun nlcs-create-layer (discipline-code layer-name / layer full-name)
  ; Create a NLCS layer with correct properties
  (setq full-name (strcat discipline-code "-" layer-name))
  (command "-LAYER" "MAKE" full-name)
  full-name
)

